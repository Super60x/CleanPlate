---
import '../styles/global.css';

const siteName = "Clean Plate AI";
const tagline = "Eat Clean, Anywhere";
const description = "Scan any restaurant menu with AI. Get instant health scores, USDA-verified nutrition data, and personalized recommendations. Free 7-day trial.";
const siteUrl = "https://cleanplateai.com";

const features = [
  { icon: "scan", title: "Unlimited Menu Scans", desc: "Point your camera at any restaurant menu and get instant analysis." },
  { icon: "nutrition", title: "USDA-Verified Nutrition", desc: "Real nutrition data from the USDA FoodData Central database." },
  { icon: "heart", title: "Personalized Scores", desc: "Health scores tailored to your dietary goals and restrictions." },
  { icon: "history", title: "Full Scan History", desc: "Save and revisit every restaurant you've analyzed." },
];

const steps = [
  { num: "1", title: "Snap", desc: "Take a photo of any restaurant menu", image: "/images/screen4.png" },
  { num: "2", title: "Analyze", desc: "AI reads every dish and scores it 1-100", image: "/images/screen3.png" },
  { num: "3", title: "Eat Smart", desc: "See what's clean, what to avoid, and why", image: "/images/screen2.png" },
];

const faqs = [
  { q: "How does Clean Plate analyze menus?", a: "We use AI to read your menu photo and analyze every dish. Nutrition data is then cross-referenced with the USDA FoodData Central database for verified accuracy." },
  { q: "What dietary preferences are supported?", a: "Vegan, vegetarian, gluten-free, dairy-free, keto, low-carb, and health goals like weight loss, muscle gain, low sugar, low sodium, and high protein." },
  { q: "Is my data private?", a: "Yes. Your scans are stored securely in your personal account. We never share your data with third parties." },
  { q: "Does it work at any restaurant?", a: "Yes — any menu you can photograph. Chain restaurants, local spots, fine dining, fast food. If you can read it, Clean Plate can analyze it." },
  { q: "What happens after the free trial?", a: "Your 7-day trial gives you full premium access. After that, choose monthly or annual billing. Cancel anytime — you won't be charged if you cancel before the trial ends." },
  { q: "How accurate is the nutrition data?", a: "Dishes matched to the USDA database show verified data with a USDA badge. For dishes without an exact match, our AI provides informed estimates clearly labeled as such." },
];

const diets = ["Vegan", "Vegetarian", "Gluten-Free", "Dairy-Free", "Keto", "Low-Carb", "High-Protein", "Low-Sugar"];

// Store links (update these when approved)
const appStoreUrl = "#waitlist";
const playStoreUrl = "https://play.google.com/store/apps/details?id=com.cleanplateai.app";

// Testimonials — diverse personas
const testimonials = [
  { name: "Sarah M.", tag: "Keto", text: "I've been doing keto for 2 years and eating out was always stressful. Clean Plate found me a perfect 9.2-scored steak bowl I never would've spotted. It actually understands macro ratios.", avatar: "SM" },
  { name: "David R.", tag: "Fitness", text: "As someone tracking macros for bodybuilding, this is a game changer. I scanned my go-to restaurant and found 3 high-protein dishes I'd been overlooking. 38g protein, verified by USDA.", avatar: "DR" },
  { name: "Priya K.", tag: "Vegetarian", text: "Finally an app that doesn't just say 'salad'. It scored every vegetarian option and told me which ones actually had complete proteins. The personalization is incredible.", avatar: "PK" },
  { name: "Marcus J.", tag: "Allergies", text: "I have a severe nut allergy. Clean Plate flagged hidden almond flour in a dish I was about to order. The warnings saved me a trip to the ER. Worth every penny.", avatar: "MJ" },
  { name: "Emma L.", tag: "Weight Loss", text: "I lost 12 lbs in 2 months just by scanning menus before ordering. Turns out my 'healthy' chicken wrap was worse than the burger. The scores don't lie.", avatar: "EL" },
  { name: "James T.", tag: "Diabetic", text: "Managing blood sugar while eating out was impossible. Now I scan the menu and instantly see which dishes are low-sugar. My A1C has improved since using this.", avatar: "JT" },
  { name: "Lisa W.", tag: "Vegan", text: "Most restaurant 'vegan' options are just carbs. Clean Plate scores them by actual nutritional value, not just the label. Found amazing plant-based protein options I'd never tried.", avatar: "LW" },
  { name: "Tom H.", tag: "Gluten-Free", text: "Celiac disease makes dining out anxiety-inducing. The warnings catch hidden gluten in sauces and marinades that even waiters miss. I feel safe ordering again.", avatar: "TH" },
  { name: "Nina C.", tag: "Clean Eating", text: "I don't follow a specific diet — I just want to eat clean. The health scores make it so simple. Green score = order it. Red score = skip it. No overthinking.", avatar: "NC" },
  { name: "Alex P.", tag: "High Protein", text: "Trying to hit 150g protein daily while traveling for work. I scan hotel restaurant menus and it instantly finds the highest protein options. Saved my meal prep routine.", avatar: "AP" },
];
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- SEO -->
  <title>{siteName} — Scan Any Restaurant Menu for Health Scores</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="restaurant menu scanner, healthy eating app, nutrition scanner, clean eating, menu health score, USDA nutrition, dietary restrictions app" />
  <link rel="canonical" href={siteUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${siteName} — ${tagline}`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:image" content={`${siteUrl}/images/og-image.png`} />
  <meta property="og:site_name" content={siteName} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${siteName} — ${tagline}`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}/images/og-image.png`} />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": siteName,
    "operatingSystem": "iOS, Android",
    "applicationCategory": "HealthApplication",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "description": description,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "ratingCount": "1"
    }
  })} />
</head>

<body class="bg-surface antialiased">

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/images/logo.svg" alt="Clean Plate logo" width="36" height="36" class="rounded-lg" />
        <span class="font-['Poppins'] font-bold text-lg text-text-main">Clean Plate</span>
      </a>
      <div class="hidden sm:flex items-center gap-6 text-sm text-text-secondary">
        <a href="#how-it-works" class="hover:text-primary transition-colors">How It Works</a>
        <a href="#features" class="hover:text-primary transition-colors">Features</a>
        <a href="#pricing" class="hover:text-primary transition-colors">Pricing</a>
        <a href="#faq" class="hover:text-primary transition-colors">FAQ</a>
      </div>
      <a href="#waitlist" class="bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-colors">
        Get Early Access
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="bg-hero-bg pt-28 pb-16 sm:pt-36 sm:pb-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      <div class="flex-1 text-center lg:text-left">
        <p class="text-primary font-semibold text-sm uppercase tracking-wider mb-3">AI-Powered Menu Scanner</p>
        <h1 class="font-['Poppins'] text-4xl sm:text-5xl lg:text-6xl font-bold text-text-main leading-tight">
          Eat Clean,<br /><span class="text-primary">Anywhere</span>
        </h1>
        <p class="mt-5 text-lg text-text-secondary max-w-xl mx-auto lg:mx-0">
          Scan any restaurant menu. Get instant health scores, USDA-verified nutrition data, and personalized recommendations — in seconds.
        </p>

        <!-- Free trial callout — prominent -->
        <div class="mt-6 inline-flex items-center gap-2 bg-primary/10 border border-primary/30 rounded-full px-5 py-2.5 mx-auto lg:mx-0">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          <span class="text-primary-dark font-bold text-sm">7-Day Free Trial</span>
          <span class="text-text-secondary text-sm">·</span>
          <span class="text-text-secondary font-medium text-sm">Cancel anytime, no commitment</span>
        </div>

        <!-- Store badges -->
        <div class="mt-7 flex flex-wrap justify-center lg:justify-start gap-4">
          <a href={appStoreUrl} class="inline-block hover:opacity-80 transition-opacity">
            <img src="/images/app-store-badge.svg" alt="Download on the App Store" width="150" height="50" class="h-[50px] w-auto" />
          </a>
          <a href={playStoreUrl} class="inline-block hover:opacity-80 transition-opacity">
            <img src="/images/google-play-badge.svg" alt="Get it on Google Play" width="168" height="50" class="h-[50px] w-auto" />
          </a>
        </div>

        <!-- Waitlist form — standout -->
        <div id="waitlist" class="mt-6 max-w-md mx-auto lg:mx-0">
          <p class="text-sm font-semibold text-text-main mb-2">Not launched in your country yet? Get notified:</p>
          <div class="flex flex-col sm:flex-row gap-3 bg-white rounded-2xl p-2 shadow-lg border border-gray-200">
            <input
              type="email"
              id="waitlist-email"
              placeholder="Enter your email"
              class="flex-1 px-4 py-3 rounded-xl text-base focus:outline-none bg-transparent"
            />
            <button
              id="waitlist-btn"
              class="bg-primary hover:bg-primary-dark text-white font-bold px-6 py-3 rounded-xl transition-colors whitespace-nowrap text-base shadow-md shadow-primary/25"
            >
              Notify Me
            </button>
          </div>
        </div>
        <p id="waitlist-msg" class="mt-3 text-sm text-text-secondary hidden"></p>

        <!-- Trust badges -->
        <div class="mt-8 flex flex-wrap justify-center lg:justify-start gap-4">
          <div class="flex items-center gap-2 bg-white/70 px-4 py-2 rounded-full text-sm text-text-secondary border border-border">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            USDA Verified Data
          </div>
          <div class="flex items-center gap-2 bg-white/70 px-4 py-2 rounded-full text-sm text-text-secondary border border-border">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            AI-Powered Analysis
          </div>
          <div class="flex items-center gap-2 bg-white/70 px-4 py-2 rounded-full text-sm text-text-secondary border border-border">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            iOS + Android
          </div>
        </div>
      </div>

      <!-- Phone mockup -->
      <div class="flex-shrink-0 relative">
        <div class="w-[280px] sm:w-[300px] mx-auto">
          <div class="bg-black rounded-[2.5rem] p-3 shadow-2xl">
            <div class="rounded-[2rem] overflow-hidden">
              <img src="/images/screen3.png" alt="Clean Plate app showing menu analysis with health scores" width="600" height="1300" class="w-full h-auto" loading="eager" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-['Poppins'] text-3xl sm:text-4xl font-bold text-text-main">
        Restaurant menus don't tell you<br class="hidden sm:block" /> what's actually healthy
      </h2>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
        "Light" salads loaded with sugar. "Grilled" dishes drenched in butter. You're guessing every time you eat out.
      </p>
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-8">
        <div class="flex flex-col items-center gap-3">
          <div class="w-14 h-14 rounded-2xl bg-red-50 flex items-center justify-center">
            <svg class="w-7 h-7 text-score-red" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
          </div>
          <h3 class="font-semibold text-text-main">Misleading Labels</h3>
          <p class="text-sm text-text-secondary">"Healthy" dishes that are actually high in sugar, sodium, and hidden fats.</p>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-14 h-14 rounded-2xl bg-yellow-50 flex items-center justify-center">
            <svg class="w-7 h-7 text-score-yellow" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-semibold text-text-main">No Nutrition Info</h3>
          <p class="text-sm text-text-secondary">Most restaurants don't list calories, macros, or ingredients on their menus.</p>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-14 h-14 rounded-2xl bg-orange-50 flex items-center justify-center">
            <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
          </div>
          <h3 class="font-semibold text-text-main">Impossible to Compare</h3>
          <p class="text-sm text-text-secondary">You can't objectively compare dishes when you're staring at a menu under pressure.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="py-16 sm:py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <h2 class="font-['Poppins'] text-3xl sm:text-4xl font-bold text-text-main">How It Works</h2>
        <p class="mt-4 text-lg text-text-secondary">Three steps. Ten seconds. Every dish scored.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {steps.map((step) => (
          <div class="flex flex-col items-center text-center">
            <div class="w-12 h-12 rounded-full border-2 border-primary text-primary font-['Poppins'] font-bold text-xl flex items-center justify-center mb-6">
              {step.num}
            </div>
            <div class="w-[200px] mx-auto mb-6">
              <div class="bg-black rounded-[2rem] p-2 shadow-lg">
                <div class="rounded-[1.6rem] overflow-hidden h-[380px]">
                  <img src={step.image} alt={`Step ${step.num}: ${step.title}`} width="400" height="867" class="w-full h-auto" loading="lazy" />
                </div>
              </div>
            </div>
            <h3 class="font-['Poppins'] text-xl font-bold text-text-main">{step.title}</h3>
            <p class="mt-2 text-text-secondary">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="py-16 sm:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <h2 class="font-['Poppins'] text-3xl sm:text-4xl font-bold text-text-main">Everything You Need to Eat Clean</h2>
        <p class="mt-4 text-lg text-text-secondary">Powerful features backed by real nutrition science.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {features.map((f) => (
          <div class="bg-white border border-gray-200 rounded-2xl p-8">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4">
              {f.icon === "scan" && <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9V5a2 2 0 012-2h4M3 15v4a2 2 0 002 2h4m8-18h4a2 2 0 012 2v4m0 6v4a2 2 0 01-2 2h-4" /></svg>}
              {f.icon === "nutrition" && <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>}
              {f.icon === "heart" && <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>}
              {f.icon === "history" && <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
            </div>
            <h3 class="font-['Poppins'] text-lg font-bold text-text-main">{f.title}</h3>
            <p class="mt-2 text-text-secondary">{f.desc}</p>
          </div>
        ))}
      </div>

      <!-- Diet tags -->
      <div class="mt-12 text-center">
        <p class="text-sm text-text-secondary mb-4">Works with your dietary preferences:</p>
        <div class="flex flex-wrap justify-center gap-2">
          {diets.map((diet) => (
            <span class="px-4 py-1.5 rounded-full bg-primary-light text-primary-dark text-sm font-medium">{diet}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS — double carousel -->
  <section class="py-16 sm:py-24 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="font-['Poppins'] text-3xl sm:text-4xl font-bold text-text-main">Loved by Every Kind of Eater</h2>
        <p class="mt-4 text-lg text-text-secondary">Personalized for your diet, your goals, your life.</p>
      </div>
    </div>

    <!-- Row 1 — scrolls left -->
    <div class="relative mb-6">
      <div class="testimonial-track-left flex gap-5 w-max">
        {[...testimonials.slice(0, 5), ...testimonials.slice(0, 5)].map((t) => (
          <div class="flex-shrink-0 w-[340px] bg-gray-50 border border-border rounded-2xl p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-primary/10 text-primary font-bold text-sm flex items-center justify-center">{t.avatar}</div>
              <div>
                <p class="font-semibold text-text-main text-sm">{t.name}</p>
                <span class="inline-block mt-0.5 px-2.5 py-0.5 rounded-full bg-primary/10 text-primary-dark text-xs font-semibold">{t.tag}</span>
              </div>
              <div class="ml-auto flex gap-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-4 h-4 text-score-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
              </div>
            </div>
            <p class="text-text-secondary text-sm leading-relaxed">"{t.text}"</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Row 2 — scrolls right -->
    <div class="relative">
      <div class="testimonial-track-right flex gap-5 w-max">
        {[...testimonials.slice(5, 10), ...testimonials.slice(5, 10)].map((t) => (
          <div class="flex-shrink-0 w-[340px] bg-gray-50 border border-border rounded-2xl p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-primary/10 text-primary font-bold text-sm flex items-center justify-center">{t.avatar}</div>
              <div>
                <p class="font-semibold text-text-main text-sm">{t.name}</p>
                <span class="inline-block mt-0.5 px-2.5 py-0.5 rounded-full bg-primary/10 text-primary-dark text-xs font-semibold">{t.tag}</span>
              </div>
              <div class="ml-auto flex gap-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-4 h-4 text-score-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
              </div>
            </div>
            <p class="text-text-secondary text-sm leading-relaxed">"{t.text}"</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="py-16 sm:py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="font-['Poppins'] text-3xl sm:text-4xl font-bold text-text-main">See It in Action</h2>
