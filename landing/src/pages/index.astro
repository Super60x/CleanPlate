  <!-- Waitlist form script -->
  <script>
    const btn = document.getElementById('waitlist-btn');
    const input = document.getElementById('waitlist-email') as HTMLInputElement;
    const msg = document.getElementById('waitlist-msg');

    btn?.addEventListener('click', async () => {
      const email = input?.value?.trim();
      if (!email || !email.includes('@')) {
        if (msg) {
          msg.textContent = 'Please enter a valid email address.';
          msg.className = 'mt-3 text-sm text-score-red';
          msg.classList.remove('hidden');
        }
        return;
      }

      if (btn) {
        btn.textContent = 'Sending...';
        btn.setAttribute('disabled', 'true');
        btn.classList.add('opacity-60');
      }

      try {
        const res = await fetch('https://formspree.io/f/mlgzrwaj', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (res.ok) {
          if (msg) {
            msg.textContent = "You're on the list! We'll notify you when Clean Plate launches.";
            msg.className = 'mt-3 text-sm text-primary font-medium';
            msg.classList.remove('hidden');
          }
          if (input) input.value = '';
          if (btn) btn.textContent = 'Joined!';
        } else {
          throw new Error('Failed');
        }
      } catch {
        if (msg) {
          msg.textContent = 'Something went wrong. Please try again.';
          msg.className = 'mt-3 text-sm text-score-red';
          msg.classList.remove('hidden');
        }
        if (btn) {
          btn.textContent = 'Notify Me';
          btn.removeAttribute('disabled');
          btn.classList.remove('opacity-60');
        }
      }
    });

    // Enter key support
    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') btn?.click();
    });
  </script>

